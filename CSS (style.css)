body {
    font-family: Arial;
    margin: 0;
    background: #f4f4f4;
    color: #333;
}

header {
    background: #0077b6;
    color: white;
    padding: 10px;
    display: flex;
    justify-content: space-between;
}

nav {
    background: #023e8a;
    padding: 10px;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
}

section {
    padding: 20px;
}

#home img {
    width: 150px;
    border-radius: 50%;
}

.card {
    background: white;
    padding: 10px;
    margin: 10px 0;
    box-shadow: 0 0 5px gray;
}

#gallery img {
    width: 150px;
    margin: 5px;
}

.dark-mode {
    background: #121212;
    color: white;
}
